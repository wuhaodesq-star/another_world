# Environment variables required by Another World tooling.
# Copy to .env (gitignored) and fill in values out-of-band.

# Weights & Biases
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=another_world

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=

# Crawler proxy (set when running stage 1.2 crawls)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Hugging Face (for tokenizers / models)
HF_TOKEN=
HF_HOME=./.cache/hf

# Misc
PYTHONHASHSEED=0
