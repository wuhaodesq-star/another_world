# Normalize line endings to LF for all text files.
* text=auto eol=lf

# Binary files (do not normalize).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.tar  binary
*.gz   binary
*.bin  binary
*.pt   binary
*.pth  binary
*.safetensors binary
*.ckpt binary
*.onnx binary
*.mp4  binary
*.webm binary
*.mkv  binary
*.wav  binary
*.mp3  binary
